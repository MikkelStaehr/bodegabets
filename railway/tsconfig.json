{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "outDir": "dist",
    "rootDir": "..",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "baseUrl": "..",
    "paths": {
      "@/lib/supabase": ["./railway/lib-shims/supabase"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "index.ts",
    "lib-shims/supabase.ts",
    "../lib/syncMatchScores.ts",
    "../lib/syncLeagueMatches.ts",
    "../lib/calculatePoints.ts",
    "../lib/betUtils.ts",
    "../lib/betTypes.ts",
    "../lib/teamNameNormalizer.ts",
    "../lib/calculateCyclingPoints.ts",
    "../lib/evaluateBlocks.ts",
    "../lib/evaluateAchievements.ts"
  ]
}
